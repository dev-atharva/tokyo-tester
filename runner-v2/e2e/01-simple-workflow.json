{
  "name": "Simple e2e workflow",
  "description": "Basic test with database seeded with privion time",
  "services_request": {
    "services": [
      {
        "name": "postgres",
        "type": "postgres",
        "env": {
          "POSTGRES_DB": "testdb",
          "POSTGRES_USER": "testuser",
          "POSTGRES_PASSWORD": "testpass"
        },
        "init_scripts": [
          "CREATE TABLE users (id SERIAL PRIMARY KEY, name VARCHAR(100), email VARCHAR(100))",
          "INSERT INTO users (name,email) VALUES ('Alice','alice@example.com'),('Bob','bob@example.com')"
        ]
      }
    ]
  },
  "test_request": {
    "tests": [
      {
        "name": "verify_user_count",
        "type": "database",
        "depends_on": ["postgres"],
        "config": {
          "service": "postgres",
          "driver": "postgres",
          "database": "testdb",
          "user": "testuser",
          "password": "testpass",
          "query": "SELECT COUNT(*) as count FROM users"
        }
      },
      {
        "name": "verify_users_exist",
        "type": "database",
        "depends_on": ["postgres"],
        "config": {
          "service": "postgres",
          "driver": "postgres",
          "database": "testdb",
          "user": "testuser",
          "password": "testpass",
          "query": "SELECT name,email FROM users ORDER BY name"
        }
      }
    ]
  }
}
