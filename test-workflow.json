    {
      "name": "User saved in DB",
      "description": "The api updates data in db.",
      "tests": [
        {
          "id": "fbbf199d-0bce-44ea-8e95-cd671beedb76",
          "name": "test-api-create-user-api",
          "type": "http",
          "targetServices": [
            "test-api"
          ],
          "httpConfig": {
            "method": "POST",
            "path": "/users",
            "port": "8081",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": "{\n\"name\": \"Atharva\",\n\"email\":\"atharva@athu.com\",\n\"status\":\"inactive\"\n}",
            "expectedStatus": 200,
            "expectedBody": {
              "mode": "contains",
              "value": "Atharva"
            }
          }
        },
        {
          "id": "dc913a68-2c66-4691-94ab-a7778f1f6dee",
          "name": "data-in-db",
          "type": "database",
          "targetServices": [
            "postgresql"
          ],
          "databaseConfig": {
            "driver": "postgres",
            "database": "testdb",
            "user": "postgres",
            "password": "postgres",
            "query": "Select name from users where name = 'Atharva';",
            "expectedResult": {
              "mode": "single",
              "value": "Atharva"
            }
          },
          "documentConfig": {
            "service": "postgresql",
            "database": "testdb",
            "collection": "",
            "operation": "find_one",
            "filter": {}
          }
        },
        {
