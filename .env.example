# Shared Database Configuration (runner + ui-v2 auth)
APP_ENV=development
LOG_LEVEL=debug
PORT=8080
OTEL_ENABLED=false
CORS_ORIGIN=http://localhost:3000
DB_TYPE=sqlite
DB_PATH=./data/cots.db
# DATABASE_URL=postgres://cots:cots_password@postgres:5432/cots

# Auth.js (ui-v2)
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TRUST_HOST=true
# AUTH_URL=http://localhost:3000

# Embedded SQLite workflow worker. Generate the encryption key with:
# openssl rand -base64 32
WORKFLOW_WORKER_ENABLED=true
WORKFLOW_WORKER_CONCURRENCY=2
WORKFLOW_SCENARIO_CONCURRENCY=2
WORKFLOW_JOB_LEASE_SECONDS=60
WORKFLOW_JOB_HEARTBEAT_SECONDS=15
WORKFLOW_JOB_MAX_RECOVERIES=3
WORKFLOW_EVENT_RETENTION_DAYS=30
WORKFLOW_JOB_ENCRYPTION_KEY=

# Optional override when the runner cannot reach mapped container ports
# TESTCONTAINERS_HOST_OVERRIDE=host.docker.internal
# Optional Docker socket path; `make dev` auto-detects it when unset
# DOCKER_SOCKET_PATH=/var/run/docker.sock
# Optional override only if you need a non-default in-container Docker socket path
# CONTAINER_DOCKER_SOCKET_PATH=/var/run/docker.sock
# Optional override only if the runner container needs a non-default Docker Host
# RUNNER_DOCKER_HOST=unix:///var/run/docker.sock
# Optional override used by `make dev` when it falls back to a host runner
# HOST_RUNNER_API_URL=http://host.docker.internal:8080
# Optional override for the host-runner SQLITE path
# HOST_RUNNER_DB_PATH=./runner-v2/data/cots.db
